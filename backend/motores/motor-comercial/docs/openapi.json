              "data": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string"
                  },
                  "motor": {
                    "type": "string"
                  },
                  "version": {
                    "type": "string"
                  },
                  "uptime": {
                    "type": "string"
                  },
                  "timestamp": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "database": {
                    "type": "string"
                  },
                  "repositories": {
                    "type": "string"
                  }
                }
              }
            }
          }
        ]
      },
      "VersionResponse": {
        "allOf": [
